# --- LLM providers ---
# Gemini is the default provider. Get a free key at https://aistudio.google.com
GEMINI_API_KEY=
# Optional: enables "Claude" in the model switcher (paid, https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Optional: enables "OpenAI" in the model switcher (paid, https://platform.openai.com)
OPENAI_API_KEY=

# --- Job sources (all optional; Remotive + Arbeitnow need no keys) ---
# Free keys at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Free tier: https://rapidapi.com -> subscribe to JSearch
RAPIDAPI_KEY=

# --- App ---
CORS_ORIGINS=http://localhost:5173
