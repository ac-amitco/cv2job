# --- LLM providers ---
# Gemini is the default provider. Get a free key at https://aistudio.google.com
GEMINI_API_KEY=
# Optional: set DEFAULT_LLM=claude to use Claude (paid, https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Optional: set DEFAULT_LLM=openai to use OpenAI (paid, https://platform.openai.com)
OPENAI_API_KEY=

# --- Job sources (all optional; Remotive + Arbeitnow need no keys) ---
# Free keys at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Free tier: https://rapidapi.com -> subscribe to JSearch
RAPIDAPI_KEY=

# --- App ---
# Which AI provider serves the app (developer-only; not exposed in the UI).
# One of: gemini | claude | openai — its API key above must be set.
DEFAULT_LLM=gemini
CORS_ORIGINS=http://localhost:5173
